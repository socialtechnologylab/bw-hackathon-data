# ENTSO-E API key (https://transparency.entsoe.eu/, request via email)
# Either a single key or a comma-separated list for round-robin rate-limit handling.
ENTSOE_API_KEY=
# ENTSOE_API_KEYS=key1,key2,key3

# Optional: GitHub token for `gh release create`. If unset, `gh auth login` is used.
# GH_TOKEN=
